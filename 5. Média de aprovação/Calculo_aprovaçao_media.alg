Algoritmo "Verificaçăo de Nota"

// Disciplina: Lógica de Programaçăo (LOPAL)
// Professor: Raul Porto Lopes
// Autor:Gabriel de Araujo Torres N°08
// Data atual: 13/04/2026

   // Funçăo: Calcular a média de 3 notas. O programa deve verificar as seguintes condiçőes:
   // Se a nota for maior ou igual a 7, o aluno está aprovado.
   // Se a nota for maior ou igual a 4 e menor que 7, o aluno está em recuperaçăo.
   // Se a nota for menor que 4, o aluno está reprovado.

Var
   n1, n2, n3, media : real

Inicio
   // Entrada de dados
   Escreval("--- Descubra suas médias de aprovaçăo aqui ---")
   Escreval("Insira a sua nota final da primeira etapa: ")
   Leia(n1)
   limpatela
   Escreval("Insira a sua nota final da segunda etapa: ")
   leia(n2)
   limpatela
   escreval("Insira a sua nota final da terceira etapa: ")
   leia(n3)
   limpatela
   
   // Processamento
   // Cálculo da média :D

   media <- (n1 + n2 + n3) / 3
   
   Se media >= 7 Entao
      Escreva("Sua média é: ", media, " Vocę está aprovado! :)")
   Senao
   Se media <= 4 Entao
         Escreva("Sua média é: ", media, " Vocę está de recuperaçăo! :(")
   senao
         Escreva("Sua média é: ", media, " Vocę está de reprovado! :(")
      fimse
      fimse

Fimalgoritmo









